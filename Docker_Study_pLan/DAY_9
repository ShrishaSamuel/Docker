Docker Compose — Health Checks, depends_on, Override Files
Why These Three Work Together
depends_on  ──controls──►  start order
healthcheck ──reports──►   service readiness
override    ──controls──►  environment-specific config
Without healthchecks, depends_on only guarantees the container started, not that the app inside is ready.

Step-by-Step Hands-On Practice
Step 1 — See the Problem Without Healthchecks
mkdir healthcheck-demo && cd healthcheck-demo

docker-compose.yml (broken — no healthcheck):
version: "3.9"
services:
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_PASSWORD: secret

  app:
    image: alpine
    command: sh -c "echo 'Connecting to DB...' && sleep 2 && echo 'Connected!'"
    depends_on:
      - db          # only waits for container to START, not for postgres to be READY

docker compose up
# app starts immediately — postgres isn't ready yet
# In real apps: "Connection refused" errors
docker compose down

Step 2 — Add a Healthcheck to the DB Service
version: "3.9"
services:
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_PASSWORD: secret
      POSTGRES_USER: appuser
      POSTGRES_DB: appdb
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U appuser -d appdb"]
      interval: 10s      # run check every 10s
      timeout: 5s        # fail if no response in 5s
      retries: 5         # mark unhealthy after 5 consecutive failures
      start_period: 15s  # grace period before first check (startup time)

  app:
    image: alpine
    command: sh -c "echo 'DB is ready! Connecting...' && sleep 1 && echo 'Done'"
    depends_on:
      db:
        condition: service_healthy   # waits for healthcheck to pass ✓

docker compose up
# app waits until postgres healthcheck passes, THEN starts
docker compose ps    # see health status column
docker compose down

Step 3 — Healthcheck Conditions Reference
depends_on:
  db:
    condition: service_started    # default: just started (no healthcheck needed)
  cache:
    condition: service_healthy    # healthcheck must be passing
  migrator:
    condition: service_completed_successfully  # one-shot job must exit 0

Step 4 — Healthchecks for Different Services
Full docker-compose.yml with multiple service types:

version: "3.9"

volumes:
  pgdata:
  redisdata:

networks:
  app-net:

services:

  # ── PostgreSQL ──────────────────────────────────────────────────────────────
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER:     ${POSTGRES_USER:-appuser}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-secret}
      POSTGRES_DB:       ${POSTGRES_DB:-appdb}
    volumes:
      - pgdata:/var/lib/postgresql/data
    networks:
      - app-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-appuser} -d ${POSTGRES_DB:-appdb}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

  # ── Redis ───────────────────────────────────────────────────────────────────
  cache:
    image: redis:7-alpine
    volumes:
      - redisdata:/data
    networks:
      - app-net
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]   # returns PONG when ready
      interval: 5s
      timeout: 3s
      retries: 3

  # ── DB Migration (one-shot job) ─────────────────────────────────────────────
  migrator:
    image: alpine
    command: sh -c "echo 'Running migrations...' && sleep 3 && echo 'Migrations done'"
    networks:
      - app-net
    depends_on:
      db:
        condition: service_healthy
    restart: "no"    # do not restart after exit

  # ── Node.js Application ─────────────────────────────────────────────────────
  app:
    image: node:20-alpine
    working_dir: /app
    command: sh -c "node -e \"require('http').createServer((_,r)=>{r.end('ok')}).listen(3000)\""
    ports:
      - "3000:3000"
    networks:
      - app-net
    depends_on:
      db:
        condition: service_healthy
      cache:
        condition: service_healthy
      migrator:
        condition: service_completed_successfully  # app starts only after migrations
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3000 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s

  # ── Nginx Reverse Proxy ─────────────────────────────────────────────────────
  proxy:
    image: nginx:alpine
    ports:
      - "80:80"
    networks:
      - app-net
    depends_on:
      app:
        condition: service_healthy   # only route traffic when app is ready
    healthcheck:
      test: ["CMD-SHELL", "curl -fs http://localhost/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3

docker compose up
docker compose ps    # watch health status: starting → healthy

